---
import "../styles/global.css";

type Props = {
  lang: string;
  title: string;
  description: string;
};

const { lang, title, description } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      const header = document.querySelector("[data-header]");
      const revealItems = document.querySelectorAll("[data-reveal]");
      const menuToggle = document.querySelector("[data-menu-toggle]");
      const mobileMenu = document.querySelector("[data-mobile-menu]");
      const menuOverlay = document.querySelector("[data-menu-overlay]");
      const mobileLinks = document.querySelectorAll(".mobile-nav a");
      const applyHeaderState = () => {
        if (!header) return;
        if (window.scrollY > 8) header.classList.add("is-scrolled");
        else header.classList.remove("is-scrolled");
      };

      applyHeaderState();
      window.addEventListener("scroll", applyHeaderState, { passive: true });

      // Adaptive threshold based on screen size
      const isMobile = window.innerWidth < 760;
      const problemsThreshold = isMobile ? 0.35 : 0.6;

      // Separate observer for problems section cards
      const problemsSection = document.querySelector("#problems");
      if (problemsSection) {
        const problemCards = problemsSection.querySelectorAll("[data-reveal]");
        const lateObserver = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                lateObserver.unobserve(entry.target);
              }
            }
          },
          { threshold: problemsThreshold },
        );
        problemCards.forEach((card) => lateObserver.observe(card));
      }

      // Default observer for other elements - triggers at 15% visibility
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.15 },
      );
      
      // Only observe items outside of problems section
      revealItems.forEach((item) => {
        if (!problemsSection || !problemsSection.contains(item)) {
          observer.observe(item);
        }
      });

      const setMenuState = (isOpen) => {
        document.body.classList.toggle("menu-open", isOpen);
        if (menuToggle instanceof HTMLButtonElement) {
          menuToggle.setAttribute("aria-expanded", String(isOpen));
        }
        if (mobileMenu instanceof HTMLElement) {
          mobileMenu.setAttribute("aria-hidden", String(!isOpen));
        }
      };

      menuToggle?.addEventListener("click", () => {
        const isOpen = document.body.classList.contains("menu-open");
        setMenuState(!isOpen);
      });

      menuOverlay?.addEventListener("click", () => setMenuState(false));
      mobileLinks.forEach((link) => {
        link.addEventListener("click", () => setMenuState(false));
      });

      window.addEventListener("keydown", (event) => {
        if (event.key === "Escape") setMenuState(false);
      });

      // Parallax effect for hero logo and video
      const heroVideo = document.querySelector("[data-hero-video]");
      const heroLogo = document.querySelector("[data-hero-logo]");
      const logoImg = document.querySelector(".logo-img");
      const logoTarget = document.querySelector("[data-logo-target]");
      const siteHeader = document.querySelector("[data-header]");

      if (heroVideo && heroLogo && logoImg && logoTarget && siteHeader) {
        const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
        const heroInitialSize = parseFloat(window.getComputedStyle(heroLogo).width) || 400;

        const updateLogoAndVideoPosition = () => {
          const scrollY = window.scrollY;
          const videoHeight = window.innerHeight;

          // Finish movement before the video section is fully out.
          const travelDistance = videoHeight * 0.92;
          const scrollProgress = clamp(scrollY / travelDistance, 0, 1);

          const targetRect = logoTarget.getBoundingClientRect();
          const targetX = targetRect.left + targetRect.width / 2;
          const targetY = targetRect.top + targetRect.height / 2;

          const viewportCenterX = window.innerWidth / 2;
          const viewportCenterY = window.innerHeight / 2;
          const offsetX = (targetX - viewportCenterX) * scrollProgress;
          // Keep a visible upward arc to avoid "only-left" motion feeling.
          const arcLift = 70 * scrollProgress * (1 - scrollProgress);
          const offsetY = (targetY - viewportCenterY) * scrollProgress - arcLift;

          const endScale = targetRect.width / heroInitialSize;
          const scale = 1 - (1 - endScale) * scrollProgress;
          heroLogo.style.transform = `translate(calc(-50% + ${offsetX}px), calc(-50% + ${offsetY}px)) scale(${scale})`;

          // Hard handoff: no fade, instant switch at target point.
          const handoffStart = 0.72;
          const handoffProgress = clamp(
            (scrollProgress - handoffStart) / (1 - handoffStart),
            0,
            1,
          );
          const hasReachedHeaderSlot = scrollProgress >= 0.999;
          heroLogo.style.opacity = "1";
          heroLogo.classList.toggle("hidden", hasReachedHeaderSlot);

          // Logo in header inherits the same trajectory before settling to final place.
          const overlayScreenX = viewportCenterX + offsetX;
          const overlayScreenY = viewportCenterY + offsetY;
          const logoTranslateX = (overlayScreenX - targetX) * (1 - handoffProgress);
          const logoTranslateY = (overlayScreenY - targetY) * (1 - handoffProgress);
          const logoScale = scale + (1 - scale) * handoffProgress;
          logoImg.style.transform = `translate(${logoTranslateX}px, ${logoTranslateY}px) scale(${logoScale})`;
          logoImg.classList.toggle("is-visible", hasReachedHeaderSlot);

          // Smoothly collapse video block height to avoid blank gap before hero section.
          const collapseProgress = clamp(scrollY / (videoHeight * 1.25), 0, 1);
          const minHeight = Math.max(videoHeight * 0.78, 440);
          const currentHeight = videoHeight - (videoHeight - minHeight) * collapseProgress;
          heroVideo.style.height = `${currentHeight}px`;
        };

        // Initial calculation
        updateLogoAndVideoPosition();

        // Update on scroll
        window.addEventListener("scroll", updateLogoAndVideoPosition, { passive: true });

        // Update on resize
        window.addEventListener("resize", updateLogoAndVideoPosition);
      }
    </script>
  </body>
</html>
